NODE_ENV=development

# API / auth
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5173

# Database
# Local Postgres example:
# DATABASE_URL=postgres://itguardian:itguardian@localhost:5432/itguardian
# Offline demo only:
# DATABASE_URL=memory
DATABASE_URL=
DB_SSL=false

# Frontend build-time variables
VITE_API_URL=http://localhost:4000
VITE_FRONTEND_URL=http://localhost:5173
VITE_ENABLE_WS=true

# Demo/future integrations
ENABLE_DEMO_SEED=false
PING_MODE=mock
OCS_MODE=mock
ZABBIX_MODE=mock
STREAM_INTERVAL_MS=10000
