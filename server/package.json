{
  "name": "@it-guardian/server",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=40 --test-coverage-branches=60 --test-coverage-functions=30 --test-coverage-include=\"../client/src/components/automation/*.js\" --test-coverage-include=\"../client/src/components/serviceOrders/serviceOrderBoardUtils.js\" --test-coverage-include=\"src/domain/*.js\" --test-coverage-include=\"src/repositories/automationAccessScope.js\" --test-coverage-include=\"src/security/*.js\" --test-coverage-include=\"src/middleware/csrfOriginMiddleware.js\" --test-coverage-include=\"src/middleware/rateLimitMiddleware.js\"",
    "test:integration": "node --test test-integration/*.test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "pg-mem": "^3.0.5",
    "ws": "^8.21.0"
  }
}
